# Godot 4+ specific ignores
.godot/
*.uid
/android/

# Claude / Agent 元文件（不在项目 git 中）
.claude/
CLAUDE.md
.mcp.json
agent*.md

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
logs/

# 覆盖率数据（生成在 tests/ 或 ascend-backend/ 下）
.coverage
.coverage.*
tests/.coverage
tests/.coverage.*

# 编译产物（从 .c 自动生成）
*.so

# 控制台历史
.ascend_history

# 运行数据（归档、存档等）
save/

# 可视化输出（测试生成的 PNG，不提交）
tests/visual/output/

# Godot 编辑器插件（开发工具，非游戏代码）
ascend-frontend/addons/

# 前端资源文件（不开源：美术素材、音频等）
ascend-frontend/assets/